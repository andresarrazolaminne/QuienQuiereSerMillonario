# Nginx optimizado para Millonario - RENDIMIENTO
# Archivos estáticos servidos por Nginx (más rápido). Solo API y Socket.io van a Node.
# Cambiar /var/www/millonario por la ruta donde clonaste el proyecto.

server {
    listen 80;
    server_name millonario.tudominio.com;

    client_max_body_size 20M;

    gzip on;
    gzip_types text/plain text/css application/json application/javascript;
    gzip_min_length 1000;

    # Imágenes/videos - Nginx sirve directo desde disco (muy rápido)
    location /uploads/ {
        alias /var/www/millonario/backend/uploads/;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    # API - proxy a Node
    location /api {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # WebSocket
    location /socket.io {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
    }

    # Frontend - Nginx sirve JS/CSS/HTML directo (muy rápido)
    location / {
        root /var/www/millonario/frontend/dist;
        try_files $uri $uri/ /index.html;
        expires 7d;
        add_header Cache-Control "public, must-revalidate";
    }
}
